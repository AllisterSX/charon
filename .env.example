# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Charon signal server (paid signal source — discovery only)
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=
SIGNAL_POLL_MS=30000

# Helius (RPC + token authority check)
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# GMGN — token info enrichment (price, mcap, holders, fees). NOT used for charts.
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=5000
GMGN_MAX_RETRIES=2
GMGN_CACHE_TTL_MS=300000

# Jupiter — chart data (30s/1m/5m candles) + execution
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
JUPITER_SLIPPAGE_BPS=300

# Wallet (live mode only)
SOLANA_PRIVATE_KEY=
LIVE_MIN_SOL_RESERVE=0.05

# LLM (any OpenAI-compatible endpoint)
ENABLE_LLM=true
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_MS=60000

# DB & runtime
DB_PATH=./apex.sqlite
TRADING_MODE=dry_run
POSITION_CHECK_MS=10000
WATCHLIST_MONITOR_MS=30000
WATCHLIST_REVALIDATE_MS=600000
WATCHLIST_STATUS_PUSH_MS=300000
ENABLE_DAILY_REPORT=true
